# Get a key from https://platform.openai.com/api-keys
# Never commit .env — keep this file local only.
OPENAI_API_KEY=sk-your-key-here

# Optional — defaults to gpt-4o-mini (vision-capable, cost-effective)
# OPENAI_MODEL=gpt-4o-mini

# API server port (local: npm run dev:api). Coolify sets PORT automatically.
PORT=8787
